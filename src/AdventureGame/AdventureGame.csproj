<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <!-- Copy the dungeon resource file to the output directory so both the
       game executable and test runners can find it at runtime via
       Path.Combine(AppContext.BaseDirectory, "res", "DungeonTemplate.txt"). -->
  <ItemGroup>
    <Content Include="..\..\res\DungeonTemplate.txt" Link="res\DungeonTemplate.txt">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

</Project>
